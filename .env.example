# Copy to .env and fill in. Never commit a real .env.

# --- Required ---
# GitHub token used to read the upstream backlog and file issues on the fork.
# For a real run it must have issues:write on FORK_REPO. A classic PAT with the
# `repo` (or `public_repo`) scope, or a fine-grained PAT scoped to the fork with
# Issues: read/write, both work. Read-only is fine for DRY_RUN=1.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Repo that issues are filed on (where Devin pushes fixes).
FORK_REPO=aneeshacognition/superset

# --- Optional: upstream + tuning ---
UPSTREAM_REPO=apache/superset
STUCK_MIN_FAILURES=1
MAX_ISSUES_PER_RUN=10

# --- Optional: Devin orchestrator nudge ---
# When both are set, each newly filed issue also starts a Devin session.
# DEVIN_API_KEY is a Devin service-user token with ManageOrgSessions.
DEVIN_API_KEY=
DEVIN_ORG_ID=org-8148d42f139c44e39fac4d401c198130
# Per-session ACU cap (optional).
DEVIN_MAX_ACU=

# --- Mode ---
# 1 = list actions only (no issues, no sessions). 0 = act for real.
DRY_RUN=1
